SECRET_KEY=generate-a-long-random-secret
DJANGO_DEBUG=True
ENVIRONMENT=development
ALLOWED_HOSTS=127.0.0.1,localhost
POSTGRES_DB=guios_plus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# En produccion usa ENVIRONMENT=production. Estas opciones se activan
# automaticamente y pueden sobrescribirse solo si tu proxy lo requiere.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
TRUST_PROXY_SSL_HEADER=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_AGE=28800
SESSION_EXPIRE_AT_BROWSER_CLOSE=True
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

OPENALEX_EMAIL=your-email@example.com
OPENALEX_API_KEY=your-openalex-key
SCOPUS_API_KEY=your-scopus-key
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-key

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-mail.outlook.com
EMAIL_PORT=587
EMAIL_HOST_USER=svgamer84@outlook.com
EMAIL_HOST_PASSWORD=your-outlook-password-or-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=svgamer84@outlook.com
